# =============================================
# 每日热点追踪系统 - 环境配置
# =============================================

# LLM API 配置（OpenAI 兼容接口）
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# LLM 通用设置
LLM_TEMPERATURE=0.7

# 爬虫设置
REQUEST_TIMEOUT=30000
MAX_RETRIES=3

# 输出设置
OUTPUT_DIR=output
REPORT_FILENAME=daily_report.md
